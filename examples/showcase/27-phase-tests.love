bolo lafz_trim(s)
~~ expected: Hello World
bolo lafz_upper("hello")
~~ expected: HELLO
bolo lafz_lower("WORLD")
~~ expected: world
bolo lafz_contains("pyaar", "yaa")
~~ expected: sach
bolo lafz_replace("I miss you", "miss", "love")
~~ expected: I love you
yaad sp hai lafz_split("a,b,c", ",")
bolo lambai(sp)
~~ expected: 3
bolo lafz_join(sp, "-")
~~ expected: a-b-c

