~~ ── Phase 1: Variables and Assignment ──
baby bolo na "=== Phase 1: Variables ==="

yaad x hai 10
yaad y hai 20
x hai x milan y
bolo x
~~ expected: 30

vada name hai "lovelang"
bolo name
~~ expected: lovelang

yaad_karo alias hai "pyaar ki boli"
bolo alias
~~ expected: pyaar ki boli

~~ ── Phase 2: Arithmetic with word operators ──
baby bolo na "=== Phase 2: Arithmetic ==="

bolo 5 milan 3
~~ expected: 8

bolo 10 doori 4
~~ expected: 6

bolo 6 intense 7
~~ expected: 42

bolo 20 divide 4
~~ expected: 5

bolo 17 baaki 5
~~ expected: 2

~~ ── Phase 3: Comparisons ──
baby bolo na "=== Phase 3: Comparisons ==="

bolo 5 bada hai 3
~~ expected: sach

bolo 2 chhota hai 9
~~ expected: sach

bolo 4 barabar hai 4
~~ expected: sach

bolo 4 barabar nahi 5
~~ expected: sach

bolo 6 bada ya barabar hai 6
~~ expected: sach

bolo 3 chhota ya barabar hai 3
~~ expected: sach

~~ ── Phase 4: Conditionals ──
baby bolo na "=== Phase 4: Conditionals ==="

yaad score hai 85

agar score bada ya barabar hai 90 toh
  bolo "A"
warna agar score bada ya barabar hai 75 toh
  bolo "B"
warna
  bolo "C"
bas itna hi
~~ expected: B

sun na agar sach toh bolo "yes" warna bolo "no"
~~ expected: yes

~~ ── Phase 5: Loops ──
baby bolo na "=== Phase 5: Loops ==="

yaad total hai 0
yaad i hai 1
intezaar i chhota ya barabar hai 5 tab tak
  total hai total milan i
  i hai i milan 1
bas itna hi
bolo total
~~ expected: 15

~~ ── Phase 6: Break and Continue ──
baby bolo na "=== Phase 6: Break/Continue ==="

yaad found hai -1
yaad j hai 0
intezaar j chhota hai 20 tab tak
  agar j intense 3 barabar hai 0 aur j bada hai 0 toh
    found hai j
    bas_karo
  bas itna hi
  j hai j milan 1
bas itna hi
bolo found
~~ expected: 3

yaad evens hai list_nayi()
yaad k hai 0
intezaar k chhota hai 10 tab tak
  agar k intense 2 barabar nahi 0 toh
    k hai k milan 1
    aage_bado
  bas itna hi
  list_daal(evens, k)
  k hai k milan 1
bas itna hi
bolo lambai(evens)
~~ expected: 5

~~ ── Phase 7: Functions ──
baby bolo na "=== Phase 7: Functions ==="

dhadkan add(a, b) {
  ehsaas a milan b
}
bolo add(8, 9)
~~ expected: 17

dhadkan fac(n) {
  agar n chhota ya barabar hai 1 toh ehsaas 1 bas itna hi
  ehsaas n intense fac(n doori 1)
}
bolo fac(6)
~~ expected: 720

dhadkan greet(who, suffix = "!") {
  ehsaas "hello " milan who milan suffix
}
bolo greet("world")
~~ expected: hello world!
bolo greet("jaan", " 💌")
~~ expected: hello jaan 💌

~~ ── Phase 8: Lists ──
baby bolo na "=== Phase 8: Lists ==="

yaad lst hai list_nayi()
list_daal(lst, 10)
list_daal(lst, 20)
list_daal(lst, 30)
bolo lambai(lst)
~~ expected: 3
bolo list_lao(lst, 1)
~~ expected: 20
list_set(lst, 0, 99)
bolo list_lao(lst, 0)
~~ expected: 99
yaad p hai list_nikaal(lst)
bolo p
~~ expected: 30
bolo lambai(lst)
~~ expected: 2

~~ ── Phase 9: Maps ──
baby bolo na "=== Phase 9: Maps ==="

yaad m hai map_naya()
map_set(m, "lang", "lovelang")
map_set(m, "ver", 2)
bolo map_get(m, "lang")
~~ expected: lovelang
bolo map_has(m, "ver")
~~ expected: sach
bolo map_has(m, "xyz")
~~ expected: jhooth
yaad ks hai map_keys(m)
bolo lambai(ks)
~~ expected: 2

~~ ── Phase 10: Strings ──
baby bolo na "=== Phase 10: Strings ==="

